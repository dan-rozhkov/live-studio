{
  "name": "live-studio",
  "version": "0.1.6",
  "description": "Open-source visual CSS editor with MCP for AI agents",
  "type": "module",
  "module": "dist/live-studio.mjs",
  "bin": {
    "live-studio": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/live-studio.mjs"
    },
    "./style.css": "./dist/live-studio.css",
    "./vite": {
      "import": "./dist/vite.mjs"
    }
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "node esbuild.config.js --minify"
  },
  "keywords": [
    "css",
    "editor",
    "mcp",
    "visual",
    "design",
    "live",
    "studio"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cssstudio": "^1.1.0",
    "dompurify": "^3.4.1",
    "js-yaml": "^4.1.0",
    "lucide-preact": "^1.8.0",
    "marked": "^14.1.0",
    "ws": "^8.19.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@preact/signals": "^1.3.0",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.24.0",
    "esbuild-css-modules-plugin": "^3.1.0",
    "html-to-image": "^1.11.13",
    "immer": "^10.0.0",
    "jsdom": "^29.0.2",
    "mock-socket": "^9.3.1",
    "preact": "^10.25.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "zustand": "^5.0.0"
  }
}
