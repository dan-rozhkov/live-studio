{
  "name": "live-studio",
  "version": "0.1.0",
  "description": "Open-source visual CSS editor with MCP for AI agents",
  "type": "module",
  "main": "dist/live-studio.js",
  "module": "dist/live-studio.mjs",
  "bin": {
    "live-studio": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/live-studio.mjs",
      "require": "./dist/live-studio.js"
    },
    "./style.css": "./dist/live-studio.css"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch"
  },
  "keywords": [
    "css",
    "editor",
    "mcp",
    "visual",
    "design",
    "live",
    "studio"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicekid1/live-studio.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "lucide-preact": "^1.8.0",
    "ws": "^8.19.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@preact/signals": "^1.3.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "esbuild-css-modules-plugin": "^3.1.0",
    "immer": "^10.0.0",
    "preact": "^10.25.0",
    "typescript": "^5.6.0",
    "zustand": "^5.0.0"
  }
}
